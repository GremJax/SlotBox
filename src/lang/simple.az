using std

shape TestShape {
    TestValue int32 = 5
}

shape TestShapeChild : TestShape {
    TestFunction(int32 x) {
        print self::TestShape.TestValue * x
    }
}

shape EternalNesting {
    Nested EternalNesting?

    Nest(EternalNesting inside) {
        if self::EternalNesting.Nested == null self::EternalNesting.Nested = inside
        else self::EternalNesting.Nested.Nest(inside)
    }

    Layers() -> string {
        return "Bingus. \{self::EternalNesting.Nested?.Layers() ?? "Such is the way."}"
    }
}

shape OptionalTest1 {
    Value int32?
}

shape OptionalTest2 {
    Test1 OptionalTest1?
}

shape OptionalTest3 {
    Test2 OptionalTest2?
}

shape FunctionRemap {
    static DoSomething() {
        print "Something was done"
    }
}

shape FunctionRemap2 {
    static DoSomethingElse() {
        print "Something else was done"
    }
}

shape LongFunc : Benchmarking (
    Start -> before DoFunc
    Stop -> after DoFunc
) {
    DoFunc() {
        for i in 1 ... 100000 {
            let x = 55368
            x /= i
        }
    }
}

static Bob int32 = 5
static Explode() -> bool {
    return "NUKE" == "HELLO"
}

let testObject := TestShape
print testObject.TestValue
testObject.TestValue = 10
print testObject

let secondObject := TestShapeChild
secondObject.TestValue = 10
print secondObject
secondObject.TestFunction(5)

let depth = 0
let root := EternalNesting

