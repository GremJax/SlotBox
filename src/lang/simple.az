print Bob
print Explode()

let x = 5
print x
print x.Negate()
print "hello".Upper()
print 1 ... 6

let test1 := OptionalTest1
print test1.Value
test1.Value = 6
print test1.Value
print test1

let test2 := OptionalTest2
print test2.Test1
print test2?.Test1.Value
test2.Test1 = test1
print test2?.Test1.Value
print test2

let test3 := OptionalTest3
print test3.Test2
print test3?.Test2?.Test1?.Value ?? 100
test3.Test2 = test2
print test3?.Test2?.Test1?.Value ?? 100
print test3

print 0xF5

let funcRemap := FunctionRemap
print funcRemap
funcRemap := FunctionRemap2 (
    DoSomethingElse -> after DoSomething
)
print funcRemap
funcRemap.DoSomething()
funcRemap.DoSomethingElse()

funcRemap =: FunctionRemap
print funcRemap

let test := LongFunc
print test
test.DoFunc()
print test

extension FunctionRemap2 {
    static ExtensionCall() {       
        print "Extensions work"
    }
}

funcRemap.ExtensionCall()

print 5 + 5